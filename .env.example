# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=          # service role — backend/worker only
SUPABASE_ANON_KEY=             # also used by the frontend

# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Verification gate (MillionVerifier) ────────────────────
MILLIONVERIFIER_API_KEY=

# ─── Email finding (Hunter — only for rows missing an email) ─
HUNTER_API_KEY=

# ─── Sending (Resend) ───────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ─── Replies (Zoho IMAP) ────────────────────────────────────
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_USER=
ZOHO_IMAP_PASSWORD=            # Zoho app-specific password
ZOHO_REPLY_TO=                 # reply-to address shown on sends

# ─── Domain suggester (Domainr — optional) ──────────────────
DOMAINR_API_KEY=

# ─── Sending behavior (tuning — defaults are safe) ──────────
SEND_WINDOW_START=8
SEND_WINDOW_END=18
SEND_TIMEZONE=America/New_York
WARMUP_START_CAP=20
WARMUP_STEP=25
WARMUP_STEADY_CAP=250
MAX_BOUNCE_RATE=0.03
MAX_COMPLAINT_RATE=0.0005

# ─── Frontend (frontend/.env) ───────────────────────────────
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_API_URL=http://localhost:8000
